<h1 class="text-2xl font-bold mb-4"><%= @project.title %></h1>
<p class="mb-4"><%= @project.description %></p>


<div class="mb-6 flex gap-4 items-center">
  <%= link_to "Edit Project", edit_project_path(@project), class: "bg-yellow-500 text-white px-3 py-1 rounded" %>
  <%= link_to "Back to Projects", projects_path, class: "text-blue-600" %>
  <%= link_to "Project Report", project_reports_path(@project), class: "bg-green-600 text-white px-3 py-1 rounded" %>
  <%= link_to "Download PDF", project_reports_path(@project, format: :pdf), class: "bg-red-600 text-white px-3 py-1 rounded" %>
</div>

<h2 class="text-xl font-semibold mb-2">Issues</h2>
<%= link_to "New Issue", new_project_issue_path(@project), class: "bg-blue-600 text-white px-3 py-1 rounded mb-4 inline-block" %>

<table class="w-full bg-white shadow rounded">
  <thead>
    <tr class="bg-gray-200">
      <th class="p-2">Title</th>
      <th class="p-2">Status</th>
      <th class="p-2">Priority</th>
      <th class="p-2"></th>
    </tr>
  </thead>
  <tbody>
    <% @project.issues.each do |issue| %>
      <tr class="border-b">
        <td class="p-2"><%= link_to issue.title, issue %></td>
        <td class="p-2"><%= issue.status %></td>
        <td class="p-2"><%= issue.priority %></td>
        <td class="p-2 flex gap-2">
          <%= link_to "Edit", edit_issue_path(issue), class: "text-blue-600" %>
          <%= link_to "Delete", issue, data: { turbo_method: :delete, turbo_confirm: "Delete issue?" }, class: "text-red-600" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
