<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Kanban Board: <%= @project.title %></h1>
    <div>
      <%= link_to "Back to Project", project_path(@project), class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded mr-2" %>
      <%= link_to "New Issue", new_project_issue_path(@project), class: "bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>

  <div class="mb-4 p-4 bg-blue-50 rounded">
    <h3 class="text-md font-medium mb-2">Tip:</h3>
    <p>You can change issue status by <span class="font-bold">dragging and dropping</span> cards between columns or using the status buttons.</p>
  </div>

  <div class="kanban-board" data-controller="kanban">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
  <!-- New Issues Column -->
  <div class="bg-gray-100 rounded-lg p-4" data-kanban-target="column" data-status="new_issue" data-column-id="new_issue">
  <h2 class="text-lg font-bold mb-4 text-gray-700">New Issues</h2>
  <div class="space-y-2 min-h-[200px]">
          <% @new_issues.each do |issue| %>
            <div class="kanban-card bg-white p-3 rounded shadow-md" 
                 data-kanban-target="card" 
                 data-issue-id="<%= issue.id %>">
              <div class="flex justify-between items-start">
                <h3 class="font-medium text-gray-900"><%= issue.title %></h3>
                <span class="text-xs bg-gray-200 text-gray-800 px-2 py-1 rounded-full">
                  #<%= issue.id %>
                </span>
              </div>
              <div class="mt-2 text-sm text-gray-600 truncate">
                <%= truncate(issue.description, length: 80) if issue.respond_to?(:description) %>
              </div>
              <div class="mt-3 flex justify-between items-center">
                <span class="text-xs <%= issue.priority_color %> px-2 py-1 rounded-full">
                  P<%= issue.priority %>: <%= issue.priority_label %>
                </span>
                <div>
                  <%= link_to "View", issue_path(issue), class: "text-xs text-blue-600 hover:text-blue-800" %>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-3 gap-1">
                    <% unless issue.status == "pending" %>
                      <button data-action="click->kanban#changeStatus" 
                              data-issue-id="<%= issue.id %>" 
                              data-status="pending" 
                              class="text-xs bg-blue-500 hover:bg-blue-700 text-white py-1 px-2 rounded">
                        Pending
                      </button>
                    <% end %>
                    <% unless issue.status == "in_progress" %>
                      <button data-action="click->kanban#changeStatus" 
                              data-issue-id="<%= issue.id %>" 
                              data-status="in_progress" 
                              class="text-xs bg-yellow-500 hover:bg-yellow-700 text-white py-1 px-2 rounded">
                        Start
                      </button>
                    <% end %>
                    <% unless issue.status == "closed" %>
                      <button data-action="click->kanban#changeStatus" 
                              data-issue-id="<%= issue.id %>" 
                              data-status="closed" 
                              class="text-xs bg-purple-500 hover:bg-purple-700 text-white py-1 px-2 rounded">
                        Close
                      </button>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Pending Column -->
          <div class="bg-gray-100 rounded-lg p-4" data-kanban-target="column" data-status="pending" data-column-id="pending">
            <h2 class="text-lg font-bold mb-4 text-gray-700">Pending</h2>
            <div class="space-y-2">
              <% @pending_issues.each do |issue| %>
                <div class="kanban-card bg-white p-3 rounded shadow-md" 
                     data-kanban-target="card" 
                     data-issue-id="<%= issue.id %>">
                  <div class="flex justify-between items-start">
                    <h3 class="font-medium text-gray-900"><%= issue.title %></h3>
                    <span class="text-xs bg-gray-200 text-gray-800 px-2 py-1 rounded-full">
                      #<%= issue.id %>
                    </span>
                  </div>
                  <div class="mt-2 text-sm text-gray-600 truncate">
                    <%= truncate(issue.description, length: 80) if issue.respond_to?(:description) %>
                  </div>
                  <div class="mt-3 flex justify-between items-center">
                    <span class="text-xs <%= issue.priority_color %> px-2 py-1 rounded-full">
                      P<%= issue.priority %>: <%= issue.priority_label %>
                    </span>
                    <div>
                      <%= link_to "View", issue_path(issue), class: "text-xs text-blue-600 hover:text-blue-800" %>
                    </div>
                  </div>
                  <div class="mt-3 grid grid-cols-3 gap-1">
                    <% unless issue.status == "new_issue" %>
                      <button data-action="click->kanban#changeStatus" 
                              data-issue-id="<%= issue.id %>" 
                              data-status="new_issue" 
                              class="text-xs bg-gray-500 hover:bg-gray-700 text-white py-1 px-2 rounded">
                        New
                      </button>
                    <% end %>
                    <% unless issue.status == "in_progress" %>
                      <button data-action="click->kanban#changeStatus" 
                              data-issue-id="<%= issue.id %>" 
                              data-status="in_progress" 
                              class="text-xs bg-yellow-500 hover:bg-yellow-700 text-white py-1 px-2 rounded">
                        Start
                  </button>
                <% end %>
                <% unless issue.status == "closed" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="closed" 
                          class="text-xs bg-purple-500 hover:bg-purple-700 text-white py-1 px-2 rounded">
                    Close
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- In Progress Column -->
      <div class="bg-gray-100 rounded-lg p-4" data-kanban-target="column" data-status="in_progress" data-column-id="in_progress">
        <h2 class="text-lg font-bold mb-4 text-gray-700">In Progress</h2>
        <div class="space-y-2">
          <% @in_progress_issues.each do |issue| %>
            <div class="kanban-card bg-white p-3 rounded shadow-md" 
                 data-kanban-target="card" 
                 data-issue-id="<%= issue.id %>">
              <div class="flex justify-between items-start">
                <h3 class="font-medium text-gray-900"><%= issue.title %></h3>
                <span class="text-xs bg-gray-200 text-gray-800 px-2 py-1 rounded-full">
                  #<%= issue.id %>
                </span>
              </div>
              <div class="mt-2 text-sm text-gray-600 truncate">
                <%= truncate(issue.description, length: 80) if issue.respond_to?(:description) %>
              </div>
              <div class="mt-3 flex justify-between items-center">
                <span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded-full">
                  <%= issue.priority.to_s.humanize if issue.respond_to?(:priority) %>
                </span>
                <div>
                  <%= link_to "View", issue_path(issue), class: "text-xs text-blue-600 hover:text-blue-800" %>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-3 gap-1">
                <% unless issue.status == "pending" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="pending" 
                          class="text-xs bg-blue-500 hover:bg-blue-700 text-white py-1 px-2 rounded">
                    Backlog
                  </button>
                <% end %>
                <% unless issue.status == "resolved" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="resolved" 
                          class="text-xs bg-green-500 hover:bg-green-700 text-white py-1 px-2 rounded">
                    Resolve
                  </button>
                <% end %>
                <% unless issue.status == "closed" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="closed" 
                          class="text-xs bg-purple-500 hover:bg-purple-700 text-white py-1 px-2 rounded">
                    Close
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Resolved Column -->
      <div class="bg-gray-100 rounded-lg p-4" data-kanban-target="column" data-status="resolved" data-column-id="resolved">
        <h2 class="text-lg font-bold mb-4 text-gray-700">Resolved</h2>
        <div class="space-y-2">
          <% @resolved_issues.each do |issue| %>
            <div class="kanban-card bg-white p-3 rounded shadow-md" 
                 data-kanban-target="card" 
                 data-issue-id="<%= issue.id %>">
              <div class="flex justify-between items-start">
                <h3 class="font-medium text-gray-900"><%= issue.title %></h3>
                <span class="text-xs bg-gray-200 text-gray-800 px-2 py-1 rounded-full">
                  #<%= issue.id %>
                </span>
              </div>
              <div class="mt-2 text-sm text-gray-600 truncate">
                <%= truncate(issue.description, length: 80) if issue.respond_to?(:description) %>
              </div>
              <div class="mt-3 flex justify-between items-center">
                <span class="text-xs <%= issue.priority_color %> px-2 py-1 rounded-full">
                  P<%= issue.priority %>: <%= issue.priority_label %>
                </span>
                <div>
                  <%= link_to "View", issue_path(issue), class: "text-xs text-blue-600 hover:text-blue-800" %>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-3 gap-1">
                <% unless issue.status == "pending" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="pending" 
                          class="text-xs bg-blue-500 hover:bg-blue-700 text-white py-1 px-2 rounded">
                    Backlog
                  </button>
                <% end %>
                <% unless issue.status == "in_progress" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="in_progress" 
                          class="text-xs bg-yellow-500 hover:bg-yellow-700 text-white py-1 px-2 rounded">
                    Reopen
                  </button>
                <% end %>
                <% unless issue.status == "closed" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="closed" 
                          class="text-xs bg-purple-500 hover:bg-purple-700 text-white py-1 px-2 rounded">
                    Close
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Closed Column -->
      <div class="bg-gray-100 rounded-lg p-4" data-kanban-target="column" data-status="closed" data-column-id="closed">
        <h2 class="text-lg font-bold mb-4 text-gray-700">Closed</h2>
        <div class="space-y-2">
          <% @closed_issues.each do |issue| %>
            <div class="kanban-card bg-white p-3 rounded shadow-md" 
                 data-kanban-target="card" 
                 data-issue-id="<%= issue.id %>">
              <div class="flex justify-between items-start">
                <h3 class="font-medium text-gray-900"><%= issue.title %></h3>
                <span class="text-xs bg-gray-200 text-gray-800 px-2 py-1 rounded-full">
                  #<%= issue.id %>
                </span>
              </div>
              <div class="mt-2 text-sm text-gray-600 truncate">
                <%= truncate(issue.description, length: 80) if issue.respond_to?(:description) %>
              </div>
              <div class="mt-3 flex justify-between items-center">
                <span class="text-xs bg-purple-100 text-purple-800 px-2 py-1 rounded-full">
                  <%= issue.priority.to_s.humanize if issue.respond_to?(:priority) %>
                </span>
                <div>
                  <%= link_to "View", issue_path(issue), class: "text-xs text-blue-600 hover:text-blue-800" %>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-3 gap-1">
                <% unless issue.status == "pending" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="pending" 
                          class="text-xs bg-blue-500 hover:bg-blue-700 text-white py-1 px-2 rounded">
                    Backlog
                  </button>
                <% end %>
                <% unless issue.status == "in_progress" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="in_progress" 
                          class="text-xs bg-yellow-500 hover:bg-yellow-700 text-white py-1 px-2 rounded">
                    Reopen
                  </button>
                <% end %>
                <% unless issue.status == "resolved" %>
                  <button data-action="click->kanban#changeStatus" 
                          data-issue-id="<%= issue.id %>" 
                          data-status="resolved" 
                          class="text-xs bg-green-500 hover:bg-green-700 text-white py-1 px-2 rounded">
                    Resolve
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .kanban-card {
    cursor: grab;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .kanban-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .kanban-card.dragging {
    opacity: 0.5;
    cursor: grabbing;
  }

  [data-kanban-target="column"].drag-over {
    background-color: #f0f9ff;
    box-shadow: inset 0 0 0 2px #93c5fd;
  }
<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Kanban Board: <%= @project.title %></h1>
    <div>
      <%= link_to "Back to Project", project_path(@project), class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded mr-2" %>
      <%= link_to "New Issue", new_project_issue_path(@project), class: "bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>

  <div class="p-4 bg-blue-50 rounded mb-4">
    <p class="text-blue-800"><strong>Tip:</strong> Drag and drop issues between columns to change their status.</p>
  </div>

  <div class="kanban-board" data-controller="kanban" data-action="dragover->kanban#preventDefaults">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <!-- Pending Column -->
      <div class="bg-gray-100 rounded-lg p-4" data-kanban-target="column" data-status="pending">
        <h2 class="text-lg font-bold mb-4 text-gray-700">New</h2>
        <div class="space-y-2 min-h-[200px]">
          <% @pending_issues.each do |issue| %>
            <div class="kanban-card bg-white p-3 rounded shadow-md" 
                 data-kanban-target="card" 
                 data-issue-id="<%= issue.id %>">
              <div class="flex justify-between items-start">
                <h3 class="font-medium text-gray-900"><%= issue.title %></h3>
                <span class="text-xs bg-gray-200 text-gray-800 px-2 py-1 rounded-full">
                  #<%= issue.id %>
                </span>
              </div>
              <div class="mt-2 text-sm text-gray-600 truncate">
                <%= truncate(issue.description, length: 80) if issue.respond_to?(:description) %>
              </div>
              <div class="mt-3 flex justify-between items-center">
                <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded-full">
                  <%= issue.priority.to_s.humanize if issue.respond_to?(:priority) %>
                </span>
                <div>
                  <%= link_to "View", issue_path(issue), class: "text-xs text-blue-600 hover:text-blue-800" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- In Progress Column -->
      <div class="bg-gray-100 rounded-lg p-4" data-kanban-target="column" data-status="in_progress">
        <h2 class="text-lg font-bold mb-4 text-gray-700">In Progress</h2>
        <div class="space-y-2 min-h-[200px]">
          <% @in_progress_issues.each do |issue| %>
            <div class="kanban-card bg-white p-3 rounded shadow-md" 
                 data-kanban-target="card" 
                 data-issue-id="<%= issue.id %>">
              <div class="flex justify-between items-start">
                <h3 class="font-medium text-gray-900"><%= issue.title %></h3>
                <span class="text-xs bg-gray-200 text-gray-800 px-2 py-1 rounded-full">
                  #<%= issue.id %>
                </span>
              </div>
              <div class="mt-2 text-sm text-gray-600 truncate">
                <%= truncate(issue.description, length: 80) if issue.respond_to?(:description) %>
              </div>
              <div class="mt-3 flex justify-between items-center">
                <span class="text-xs <%= issue.priority_color %> px-2 py-1 rounded-full">
                  P<%= issue.priority %>: <%= issue.priority_label %>
                </span>
                <div class="flex space-x-2">
                  <%= link_to "View", issue_path(issue), class: "text-xs text-blue-600 hover:text-blue-800" %>
                  <%= link_to "Edit", edit_issue_path(issue), class: "text-xs text-green-600 hover:text-green-800" %>
                  <%= button_to "Delete", issue_path(issue), method: :delete, class: "text-xs text-red-600 hover:text-red-800", 
                      form: { data: { turbo_confirm: "Are you sure you want to delete this issue?" }, style: "display:inline;" } %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Resolved Column -->
      <div class="bg-gray-100 rounded-lg p-4" data-kanban-target="column" data-status="resolved">
        <h2 class="text-lg font-bold mb-4 text-gray-700">Resolved</h2>
        <div class="space-y-2 min-h-[200px]">
          <% @resolved_issues.each do |issue| %>
            <div class="kanban-card bg-white p-3 rounded shadow-md" 
                 data-kanban-target="card" 
                 data-issue-id="<%= issue.id %>">
              <div class="flex justify-between items-start">
                <h3 class="font-medium text-gray-900"><%= issue.title %></h3>
                <span class="text-xs bg-gray-200 text-gray-800 px-2 py-1 rounded-full">
                  #<%= issue.id %>
                </span>
              </div>
              <div class="mt-2 text-sm text-gray-600 truncate">
                <%= truncate(issue.description, length: 80) if issue.respond_to?(:description) %>
              </div>
              <div class="mt-3 flex justify-between items-center">
                <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full">
                  <%= issue.priority.to_s.humanize if issue.respond_to?(:priority) %>
                </span>
                <div>
                  <%= link_to "View", issue_path(issue), class: "text-xs text-blue-600 hover:text-blue-800" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Closed Column -->
      <div class="bg-gray-100 rounded-lg p-4" data-kanban-target="column" data-status="closed">
        <h2 class="text-lg font-bold mb-4 text-gray-700">Closed</h2>
        <div class="space-y-2 min-h-[200px]">
          <% @closed_issues.each do |issue| %>
            <div class="kanban-card bg-white p-3 rounded shadow-md" 
                 data-kanban-target="card" 
                 data-issue-id="<%= issue.id %>">
              <div class="flex justify-between items-start">
                <h3 class="font-medium text-gray-900"><%= issue.title %></h3>
                <span class="text-xs bg-gray-200 text-gray-800 px-2 py-1 rounded-full">
                  #<%= issue.id %>
                </span>
              </div>
              <div class="mt-2 text-sm text-gray-600 truncate">
                <%= truncate(issue.description, length: 80) if issue.respond_to?(:description) %>
              </div>
              <div class="mt-3 flex justify-between items-center">
                <span class="text-xs <%= issue.priority_color %> px-2 py-1 rounded-full">
                  P<%= issue.priority %>: <%= issue.priority_label %>
                </span>
                <div>
                  <%= link_to "View", issue_path(issue), class: "text-xs text-blue-600 hover:text-blue-800" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .kanban-card {
    cursor: grab;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .kanban-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .kanban-card.dragging {
    opacity: 0.5;
    cursor: grabbing;
    transform: scale(1.05);
  }

  [data-kanban-target="column"].drag-over {
    background-color: #f0f9ff;
    box-shadow: inset 0 0 0 2px #93c5fd;
  }

  .kanban-card.dragging {
    opacity: 0.5;
    cursor: grabbing;
  }

  [data-kanban-target="column"].drag-over {
    background-color: #f0f9ff;
    box-shadow: inset 0 0 0 2px #93c5fd;
  }
</style>
