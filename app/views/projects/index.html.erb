
<h1 class="text-3xl font-bold mb-6 text-gray-800">Projects</h1>

<div class="mb-6 flex justify-between items-center">
  <%= link_to "New Project", new_project_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded shadow" %>
</div>

<table class="w-full bg-white shadow-lg rounded-lg overflow-hidden">
  <thead>
    <tr class="bg-gray-200 text-left">
      <th class="p-3">Title</th>
      <th class="p-3">Description</th>
      <th class="p-3">Issues</th>
      <th class="p-3">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @projects.each do |project| %>
      <tr class="border-b hover:bg-gray-50 transition">
        <td class="p-3 font-semibold text-blue-700"><%= link_to project.title, project %></td>
        <td class="p-3 text-gray-700"><%= project.description %></td>
        <td class="p-3 text-center"><%= project.issues.count %></td>
        <td class="p-3 flex gap-2">
          <%= link_to "Edit", edit_project_path(project), class: "text-blue-600 hover:underline" %>
          <%= button_to "Delete", project_path(project), method: :delete, data: { confirm: "Delete project?" }, class: "text-red-600" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
