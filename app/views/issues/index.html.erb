
<h1 class="text-2xl font-bold mb-4">All Issues</h1>
<div class="mb-4">
		<%= link_to "New Issue", new_issue_path, class: "bg-blue-600 text-white px-4 py-2 rounded" %>
		<% @issues.each do |issue| %>
				<%= button_to "Delete", destroy_issue_path(issue), method: :delete, data: { confirm: "Delete issue?" }, class: "bg-red-600 text-white px-2 py-1 rounded ml-2" %>
		<% end %>
</div>
<table class="w-full bg-white shadow rounded">
	<thead>
		<tr class="bg-gray-200 text-left">
			<th class="p-2">Title</th>
			<th class="p-2">Description</th>
			<th class="p-2">Status</th>
			<th class="p-2">Priority</th>
			<th class="p-2">Project</th>
			<th class="p-2"></th>
		</tr>
	</thead>
	<tbody>
		<% @issues.each do |issue| %>
			<tr class="border-b">
				<td class="p-2"><%= link_to issue.title, issue %></td>
				<td class="p-2"><%= issue.description %></td>
				<td class="p-2"><%= display_status(issue) %></td>
				<td class="p-2"><%= issue.priority %></td>
				<td class="p-2"><%= issue.project.title %></td>
				<td class="p-2">
					<%= link_to "Edit", edit_issue_path(issue), class: "text-blue-600" %> |
						<%= button_to "Delete", destroy_issue_path(issue), method: :delete, data: { confirm: "Delete issue?" }, class: "text-red-600" %>
				</td>
			</tr>
		<% end %>
	</tbody>
</table>
