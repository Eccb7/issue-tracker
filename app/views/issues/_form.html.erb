
<%= form_with(model: issue, url: issue.persisted? ? issue_path(issue) : (defined?(@project) ? project_issues_path(@project) : issues_path), class: "space-y-6 bg-white p-6 rounded shadow") do |f| %>
  <div>
    <%= f.label :title, class: "block font-semibold mb-1" %>
    <%= f.text_field :title, class: "border rounded w-full p-2" %>
  </div>
  <div>
    <%= f.label :description, class: "block font-semibold mb-1" %>
    <%= f.text_area :description, class: "border rounded w-full p-2", rows: 3 %>
  </div>
  <div>
    <%= f.label :status, class: "block font-semibold mb-1" %>
    <%= f.select :status, [["New", "new"], ["In Progress", "in_progress"], ["Closed", "closed"]], {}, class: "border rounded w-full p-2" %>
  </div>
  <div>
    <%= f.label :priority, class: "block font-semibold mb-1" %>
    <%= f.number_field :priority, in: 1..5, class: "border rounded w-full p-2" %>
  </div>
  <%= f.submit class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded shadow" %>
<% end %>
