<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Issue Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="chartkick-rendering-wait-time" content="200">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Direct script references to ensure charts work -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/luxon@3.4.4/build/global/luxon.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-luxon@1.3.1/dist/chartjs-adapter-luxon.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js"></script>
    <script>
      document.addEventListener("DOMContentLoaded", function() {
        if (typeof Chartkick !== 'undefined' && typeof Chart !== 'undefined') {
          Chartkick.use(Chart);
          console.log("Chartkick initialized with Chart.js via CDN");
        } else {
          console.error("Chartkick or Chart.js not loaded via CDN");
        }
      });
    </script>
  </head>
  
  <body class="bg-gray-100 min-h-screen">
    <nav class="bg-gray-800 text-white p-4">
      <div class="container mx-auto flex gap-6">
        <%= link_to "Projects", projects_path, class: "hover:underline" %>
        <%= link_to "Reports", reports_path, class: "hover:underline" %>
      </div>
    </nav>

    <main class="container mx-auto mt-6 p-4">
      <% if notice %>
        <p class="bg-green-100 text-green-800 px-4 py-2 rounded mb-4"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="bg-red-100 text-red-800 px-4 py-2 rounded mb-4"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
