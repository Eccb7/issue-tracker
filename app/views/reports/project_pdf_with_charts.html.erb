<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Project Report: <%= project.name %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 40px;
      color: #333;
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    .date {
