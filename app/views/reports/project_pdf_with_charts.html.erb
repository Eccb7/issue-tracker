<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Project Report: <%= project.name %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 40px;
      color: #333;
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    .date {
      text-align: right;
      font-size: 14px;
      color: #666;
      margin-bottom: 20px;
    }
    h1 {
      font-size: 24px;
      color: #2c3e50;
    }
    h2 {
      font-size: 18px;
      color: #3498db;
      border-bottom: 1px solid #eee;
      padding-bottom: 5px;
      margin-top: 30px;
    }
    .chart-container {
      page-break-inside: avoid;
      margin: 20px 0;
      text-align: center;
    }
    .chart {
      max-width: 100%;
      height: 300px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
    }
    th, td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: left;
    }
    th {
      background-color: #f2f2f2;
      font-weight: bold;
    }
    tr:nth-child(even) {
      background-color: #f9f9f9;
    }
    .project-info {
      background-color: #f9f9f9;
      border-left: 4px solid #3498db;
      padding: 15px;
      margin-bottom: 30px;
    }
    .footer {
      text-align: center;
      font-size: 12px;
      color: #999;
      margin-top: 40px;
      border-top: 1px solid #eee;
      padding-top: 10px;
    }
  </style>
  <!-- Include Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.min.js"></script>
</head>
