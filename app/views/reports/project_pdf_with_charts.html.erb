      padding: 8px;
      text-align: left;
    }
    th {
      background-color: #f2f2f2;
      font-weight: bold;
    }
    tr:nth-child(even) {
      background-color: #f9f9f9;
    }
    .project-info {
      background-color: #f9f9f9;
      border-left: 4px solid #3498db;
      padding: 15px;
      margin-bottom: 30px;
    }
    .footer {
      text-align: center;
      font-size: 12px;
      color: #999;
      margin-top: 40px;
      border-top: 1px solid #eee;
      padding-top: 10px;
    }
  </style>
  <!-- Include Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <div class="header">
    <h1>Project Report: <%= project.name %></h1>
  </div>

  <div class="date">
    Generated on: <%= Time.now.strftime('%B %d, %Y') %>
  </div>

  <div class="project-info">
    <h2>Project Information</h2>
    <p><strong>Name:</strong> <%= project.name %></p>
    <p><strong>Total Issues:</strong> <%= issues.count %></p>
    <% if project.respond_to?(:description) && project.description.present? %>
      <p><strong>Description:</strong> <%= project.description %></p>
    <% end %>
    <% if project.respond_to?(:created_at) %>
      <p><strong>Created:</strong> <%= project.created_at.strftime('%B %d, %Y') %></p>
    <% end %>
  </div>

  <div class="chart-container">
    <h2>Issues by Status</h2>
    <div id="status-chart" class="chart"></div>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('status-chart').getContext('2d');
        new Chart(ctx, {
          type: 'pie',
          data: {
            labels: <%= raw issues.group(:status).count.keys.to_json %>,
            datasets: [{
              data: <%= raw issues.group(:status).count.values.to_json %>,
              backgroundColor: ['#3366CC', '#DC3912', '#FF9900', '#109618']
            }]
          },
          options: {
            responsive: true,
            plugins: {
              legend: { position: 'right' }
            }
          }
        });
      });
    </script>
  </div>

  <div class="chart-container">
    <h2>Issues by Priority</h2>
    <div id="priority-chart" class="chart"></div>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('priority-chart').getContext('2d');
        new Chart(ctx, {
          type: 'bar',
          data: {
            labels: <%= raw issues.group(:priority).count.keys.to_json %>,
            datasets: [{
              label: 'Number of Issues',
              data: <%= raw issues.group(:priority).count.values.to_json %>,
              backgroundColor: '#3366CC'
            }]
          },
          options: {
            responsive: true,
            scales: {
              y: { beginAtZero: true }
            }
          }
        });
      });
    </script>
  </div>

  <% if issues.present? %>
    <div class="chart-container">
      <h2>Issues Timeline</h2>
      <div id="timeline-chart" class="chart"></div>
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const ctx = document.getElementById('timeline-chart').getContext('2d');

          // Group by month for the timeline
          const dates = {};
          <% issues.group_by { |i| i.created_at.beginning_of_month.strftime('%Y-%m') }.each do |month, month_issues| %>
            dates['<%= month %>'] = <%= month_issues.count %>;
          <% end %>

          new Chart(ctx, {
            type: 'line',
            data: {
              labels: Object.keys(dates).map(date => {
                const [year, month] = date.split('-');
                return new Date(year, month - 1).toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
              }),
              datasets: [{
                label: 'Issues Created',
                data: Object.values(dates),
                borderColor: '#109618',
                backgroundColor: 'rgba(16, 150, 24, 0.2)',
                tension: 0.1,
                fill: true
              }]
            },
            options: {
              responsive: true,
              scales: {
                y: { beginAtZero: true }
              }
            }
          });
        });
      </script>
    </div>
  <% end %>

  <h2>Issues List</h2>
  <table>
    <tr>
      <th>ID</th>
      <th>Title</th>
      <th>Status</th>
      <th>Priority</th>
      <th>Created</th>
    </tr>
    <% issues.each do |issue| %>
      <tr>
        <td><%= issue.id %></td>
        <td><%= issue.title %></td>
        <td><%= issue.status %></td>
        <td><%= issue.priority %></td>
        <td><%= issue.created_at.strftime('%Y-%m-%d') %></td>
      </tr>
    <% end %>
  </table>

  <div class="footer">
    Project Report - Generated by Issue Tracker
  </div>
</body>
</html>
