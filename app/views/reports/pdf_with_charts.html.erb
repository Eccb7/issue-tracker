<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Issues Report</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 40px;
      color: #333;
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    .date {
      text-align: right;
      font-size: 14px;
      color: #666;
      margin-bottom: 20px;
    }
    h1 {
      font-size: 24px;
      color: #2c3e50;
    }
    h2 {
      font-size: 18px;
      color: #3498db;
      border-bottom: 1px solid #eee;
      padding-bottom: 5px;
      margin-top: 30px;
    }
    .chart-container {
      page-break-inside: avoid;
      margin: 20px 0;
      text-align: center;
    }
    .chart {
      max-width: 100%;
      height: 300px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
    }
    th, td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: left;
    }
    th {
      background-color: #f2f2f2;
      font-weight: bold;
    }
    tr:nth-child(even) {
      background-color: #f9f9f9;
    }
    .footer {
      text-align: center;
      font-size: 12px;
      color: #999;
      margin-top: 40px;
      border-top: 1px solid #eee;
      padding-top: 10px;
    }
  </style>
  <!-- Include Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <div class="header">
    <h1>Issues Report</h1>
  </div>

  <div class="date">
    Generated on: <%= Time.now.strftime('%B %d, %Y') %>
  </div>

  <h2>Summary</h2>
  <p>Total Issues: <%= issues.count %></p>

  <div class="chart-container">
    <h2>Issues by Status</h2>
    <div id="status-chart" class="chart"></div>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('status-chart').getContext('2d');
        new Chart(ctx, {
          type: 'pie',
          data: {
            labels: <%= raw issues.group(:status).count.keys.to_json %>,
            datasets: [{
              data: <%= raw issues.group(:status).count.values.to_json %>,
              backgroundColor: ['#3366CC', '#DC3912', '#FF9900', '#109618']
            }]
          },
          options: {
            responsive: true,
            plugins: {
              legend: { position: 'right' }
            }
          }
        });
      });
    </script>
  </div>

  <div class="chart-container">
    <h2>Issues by Priority</h2>
    <div id="priority-chart" class="chart"></div>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('priority-chart').getContext('2d');
        new Chart(ctx, {
          type: 'bar',
          data: {
            labels: <%= raw issues.group(:priority).count.keys.to_json %>,
            datasets: [{
              label: 'Number of Issues',
              data: <%= raw issues.group(:priority).count.values.to_json %>,
              backgroundColor: '#3366CC'
            }]
          },
          options: {
            responsive: true,
            scales: {
              y: { beginAtZero: true }
            }
          }
        });
      });
    </script>
  </div>

  <h2>Issues List</h2>
  <table>
    <tr>
      <th>ID</th>
      <th>Title</th>
      <th>Status</th>
      <th>Priority</th>
      <th>Created</th>
    </tr>
    <% issues.each do |issue| %>
      <tr>
        <td><%= issue.id %></td>
        <td><%= issue.title %></td>
        <td><%= issue.status %></td>
        <td><%= issue.priority %></td>
        <td><%= issue.created_at.strftime('%Y-%m-%d') %></td>
      </tr>
    <% end %>
  </table>

  <div class="footer">
    Issue Tracker Report - Generated by Rails Application
  </div>
</body>
</html>
