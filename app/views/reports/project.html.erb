<h1 class="text-2xl font-bold mb-4">Report for <%= @project.title %></h1>

<div class="mb-6">
  <h2 class="font-semibold mb-2">Issues by Status</h2>
  <%= pie_chart @issues_by_status, height: "250px" %>
</div>

<table class="w-full bg-white shadow rounded">
  <thead>
    <tr class="bg-gray-200 text-left">
      <th class="p-2">Title</th>
      <th class="p-2">Description</th>
      <th class="p-2">Status</th>
      <th class="p-2">Priority</th>
    </tr>
  </thead>
  <tbody>
    <% @issues.each do |issue| %>
      <tr class="border-b">
        <td class="p-2"><%= issue.title %></td>
        <td class="p-2"><%= issue.description %></td>
        <td class="p-2"><%= issue.status %></td>
        <td class="p-2"><%= issue.priority %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="mt-6 flex gap-3">
  <%= link_to "Download Excel", project_reports_path(@project, format: :xlsx), class: "bg-green-600 text-white px-4 py-2 rounded" %>
  <%= link_to "Download PDF", project_reports_path(@project, format: :pdf), class: "bg-red-600 text-white px-4 py-2 rounded" %>
</div>
<%= link_to "Back to Projects", projects_path, class: "mt-4 inline-block text-blue-600" %>
