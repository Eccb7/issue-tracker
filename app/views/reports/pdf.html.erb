<h1>Issues Report</h1>
<p>Generated at <%= Time.current %></p>
<table>
  <thead><tr><th>ID</th><th>Title</th><th>Status</th><th>Priority</th><th>Project</th></tr></thead>
  <tbody>
    <% @issues.each do |i| %>
      <tr>
        <td><%= i.id %></td>
        <td><%= i.title %></td>
        <td><%= i.status %></td>
        <td><%= i.priority %></td>
        <td><%= i.project.title %></td>
      </tr>
    <% end %>
  </tbody>
</table>
