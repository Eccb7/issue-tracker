
<h1 class="text-3xl font-bold mb-6 text-gray-800">Reports</h1>

<div class="grid md:grid-cols-2 gap-8">
  <div class="bg-white p-6 rounded shadow">
    <h2 class="font-semibold mb-4 text-lg">Issues by Status</h2>
    <%= pie_chart @issues_by_status, height: "250px" %>
  </div>
  <div class="bg-white p-6 rounded shadow">
    <h2 class="font-semibold mb-4 text-lg">Issues by Project</h2>
    <%= column_chart @issues_by_project, height: "250px" %>
  </div>
</div>

<div class="mt-8 flex gap-4">
  <%= link_to "Download Excel", reports_path(format: :xlsx), class: "bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded shadow" %>
  <%= link_to "Download PDF", reports_path(format: :pdf), class: "bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded shadow" %>
</div>
<%= link_to "Back to Projects", projects_path, class: "mt-6 inline-block text-blue-600 hover:underline" %>
