<h1 class="text-2xl font-bold mb-4">Issue Reports</h1>

<div class="grid md:grid-cols-2 gap-6">
  <div>
    <h2 class="font-semibold mb-2">Issues by Status</h2>
    <%= pie_chart @issues_by_status %>
  </div>
  <div>
    <h2 class="font-semibold mb-2">Issues by Project</h2>
    <%= column_chart @issues_by_project %>
  </div>
</div>

<div class="mt-6 flex gap-3">
  <%= link_to "Download Excel", reports_path(format: :xlsx), class: "btn" %>
  <%= link_to "Download PDF",   reports_path(format: :pdf),  class: "btn" %>
</div>
